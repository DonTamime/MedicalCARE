CREATE OR REPLACE TRIGGER TRG_ALERTE_EEG_CONSECUTIF
BEFORE UPDATE OF SCORE_NEUROLOGUE ON EXAM_EEG
FOR EACH ROW
DECLARE
   v_score_precedent INTEGER;
   v_id_pat          INTEGER;
BEGIN
   -- 1. On récupère l'ID du patient lié à cette visite (via une petite jointure)
   SELECT ID_PATIENT INTO v_id_pat 
   FROM VISITE_QUOTIDIENNE 
   WHERE ID_VISITE = :NEW.ID_VISITE;

   -- 2. On cherche le score du DERNIER examen EEG de ce patient (avant celui-ci)
   BEGIN
      SELECT SCORE_NEUROLOGUE INTO v_score_precedent
      FROM (SELECT SCORE_NEUROLOGUE 
            FROM EXAM_EEG 
            WHERE ID_VISITE IN (SELECT ID_VISITE FROM VISITE_QUOTIDIENNE WHERE ID_PATIENT = v_id_pat)
            AND ID_EEG < :NEW.ID_EEG -- On prend ceux d'avant
            ORDER BY DATE_EEG DESC)
      WHERE ROWNUM = 1; -- On ne prend que le plus récent
   EXCEPTION
      WHEN NO_DATA_FOUND THEN v_score_precedent := 10; -- S'il n'y a pas d'examen avant, on met un score neutre
   END;

   -- 3. La vérification fatidique
   IF :NEW.SCORE_NEUROLOGUE < 4 AND v_score_precedent < 4 THEN
      RAISE_APPLICATION_ERROR(-20020, 
         'ALERTE SÉCURITÉ : Deux scores EEG consécutifs inférieurs à 4 détectés pour ce patient ! ' ||
         '(Actuel: ' || :NEW.SCORE_NEUROLOGUE || ', Précédent: ' || v_score_precedent || ')');
   END IF;
END;

