CREATE OR REPLACE TRIGGER TRG_VERIF_IMC_AUTO
BEFORE INSERT OR UPDATE ON PATIENT
FOR EACH ROW
DECLARE
    v_imc NUMBER;
BEGIN
    -- Calcul de l'IMC : Poids (kg) / Taille² (m)
    -- Attention : TAILLE_CM est en cm dans ta table, on divise par 100
    IF :NEW.TAILLE_CM > 0 THEN
        v_imc := :NEW.POIDS_KG / POWER((:NEW.TAILLE_CM / 100), 2);

        IF v_imc < 18.5 OR v_imc > 30 THEN
            
            RAISE_APPLICATION_ERROR(-20030, 'INCLUSION REFUSÉE : IMC non conforme (' || ROUND(v_imc, 2) || ').');
        END IF;
    END IF;
END;
/